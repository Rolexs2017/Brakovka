{
  "emulator": false,
  "gpio": {
    "btn_start": 23,
    "btn_stop": 24,
    "btn_jog": 25,
    "btn_reverse": 8,
    "btn_reset_wound": 7,
    "brake_pwm": 13
  },
  "serial": {
    "port": "/dev/ttyUSB0",
    "baudrate": 115200,
    "timeout_s": 3,
    "retries": 3,
    "unit_id": 1,
    "reconnect_period_s": 2.0,
    "fails_before_reconnect": 2
  },
  "opcua": {
    "endpoint": "opc.tcp://0.0.0.0:4840/",
    "server_name": "BrakovkaPi"
  },
  "ui": {
    "window_title": "Brakovka HMI",
    "fullscreen": true,
    "gui_variant": "modern",
    "settings_password": "4444",
    "sounds_enabled": true
  },
  "timing": {
    "task_period_s": 0.01,
    "opcua_publish_period_s": 0.1,
    "opcua_poll_period_s": 0.05,
    "vfd_status_poll_period_s": 0.2,
    "vfd_cmd_period_s": 0.05,
    "vfd_cmd_min_delta_hz": 0.05,
    "watchdog_limit_s": 5.0
  },
  "encoder": {
    "i2c_bus": 1,
    "i2c_address": 54,
    "i2c_retries": 2,
    "i2c_retry_delay_s": 0.0005,
    "fault_streak": 5,
    "recover_streak": 3,
    "poll_min_period_s": 0.001
  },
  "emu": {
    "gear_ratio": 0.2
  },
  "machine": {
    "unwind_roll_length_m": 2500.0,
    "core_diameter_mm": 76.0,
    "material_thickness_mm": 0.3,
    "roll_encoder_diameter_mm": 44.0,
    "tension_setpoint_n": 150.0,
    "tension_brake_gain_n": 500.0,
    "target_length_m": 500.0,
    "speed_setpoint_mpm": 100.0,
    "slowdown_speed_mpm": 20.0,
    "slowdown_start_pct": 90.0,
    "slowdown_exit_pct": 85.0,
    "accel_time_s": 15.0,
    "decel_time_s": 10.0,
    "jog_speed_mpm": 10.0,
    "reverse_speed_mpm": 15.0,
    "brake_delay_s": 3.0,
    "pid_kp": 5.0,
    "pid_ti": 2.0,
    "pid_kd": 0.0,
    "pid_tune_method": "relay",
    "mpm_per_hz": 1.0,
    "tension_brake_min_pct": 2.0,
    "brake_max_pressure_pct": 100.0,
    "max_ramp_speed_mpm": 300.0,
    "encoder_spike_m": 2.0,
    "encoder_invert": false,
    "emu_mpm_per_hz": 1.0,
    "emu_motor_rpm_per_hz": 60.0
  }
}
